generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String      @id @default(cuid())
  name        String
  email       String      @unique
  password    String

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  jobs        AudioJob[]
}

model AudioJob {
  id            String      @id @default(cuid())

  youtubeUrl    String
  youtubeTitle  String?
  status        JobStatus   @default(PENDING)

  audioPath     String?
  instrumentalPath     String?
  vocalsPath    String?

  error       String?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}


enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
